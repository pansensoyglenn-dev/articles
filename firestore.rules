
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read your posts
    match /{document=**} {
      allow read: if true;
    }

    // Only YOU can write, update, or delete
    match /{document=**} {
      allow write: if request.auth != null && request.auth.uid == "BoAoVcHcesSe6E6bgeeUMrV4QBC2";
    }
  }
}
