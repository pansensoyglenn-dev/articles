rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public access for reading tutorial assets and documentation
    match /{allPaths=**} {
      allow read: if true;
      
      // Strict write access restricted to your specific UID
      allow write: if request.auth != null && request.auth.uid == "BoAoVcHcesSe6E6bgeeUMrV4QBC2";
    }
  }
}
